{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Agent": {
    "ModelId": "mistral",
    "EmbeddingModelId": "nomic-embed-text",
    "OllamaEndpoint": "http://localhost:11434",
    "QdrantEndpoint": "http://localhost:6333", //.\qdrant.exe
    "QdrantCollectionName": "dev-assistant-code",
    "MaxIterations": 10,
    "WorkingDirectory": "./workspace",
    "StreamingEnabled": true
  },
    "Serilog": {
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "Microsoft": "Warning",
          "System": "Warning"
        }
      }
    }  
}
