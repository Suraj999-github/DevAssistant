@{
    ViewData["Title"] = "Chat";
}

<style>
    /* ── Variables (dark theme) ─────────────────────────────────────────── */
    :root {
        --bg-darker: #0d1117;
        --bg-dark: #161b22;
        --bg-card: #1c2128;
        --border-color: #30363d;
        --text-muted: #8b949e;
        --text-primary: #e6edf3;
        --accent-blue: #58a6ff;
        --accent-green: #3fb950;
    }

    /* ── Base layout ────────────────────────────────────────────────────── */
    body {
        background-color: var(--bg-darker);
        color: var(--text-primary);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        height: 100vh;
        overflow: hidden;
        margin: 0;
        padding: 0;
    }

    /* ── Chat Layout (full height, no extra margins) ───────────────────── */
    .chat-layout {
        display: flex;
        flex-direction: column;
        height: 100vh;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        background: var(--bg-darker);
        overflow: hidden;
    }

    /* ── Scrollable messages area ───────────────────────────────────────── */
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        scroll-behavior: smooth;
    }

    /* Custom scrollbar */
    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }
    .chat-messages::-webkit-scrollbar-track {
        background: transparent;
    }
    .chat-messages::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 3px;
    }

    /* ── Message rows ───────────────────────────────────────────────────── */
    .message {
        display: flex;
        gap: 0.75rem;
        max-width: 85%;
        animation: fadeSlideUp 0.2s ease;
    }

    /* User messages align right */
    .message.user {
        flex-direction: row-reverse;
        align-self: flex-end;
    }

    /* Avatars */
    .message-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
        background: var(--bg-dark);
        border: 1px solid var(--border-color);
    }
    .message.user .message-avatar {
        background: #1f4068;
        border-color: var(--accent-blue);
        color: var(--accent-blue);
    }
    .message.assistant .message-avatar {
        background: #1a3a2a;
        border-color: var(--accent-green);
        color: var(--accent-green);
    }

    /* Bubbles */
    .message-bubble {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 0.65rem 1rem;
        font-size: 0.9rem;
        line-height: 1.6;
        word-break: break-word;
    }
    .message.user .message-bubble {
        background: #1f4068;
        border-color: #58a6ff44;
    }

    /* Code blocks inside bubbles */
    .message-bubble pre {
        background: var(--bg-darker);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        padding: 0.75rem;
        overflow-x: auto;
        font-size: 0.8rem;
        margin: 0.5rem 0;
    }
    .inline-code {
        background: rgba(110,118,129,0.2);
        padding: 0.1em 0.35em;
        border-radius: 4px;
        font-size: 0.85em;
        font-family: 'SF Mono', 'Fira Code', monospace;
    }

    /* Typing indicator (three bouncing dots) */
    .typing-indicator {
        display: flex;
        gap: 4px;
        align-items: center;
        padding: 4px 0;
    }
    .typing-indicator span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--text-muted);
        animation: bounce 1.2s infinite;
    }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes bounce {
        0%,60%,100% { transform: translateY(0); }
        30% { transform: translateY(-6px); }
    }

    /* ── Input bar (sticky bottom) ──────────────────────────────────────── */
    .chat-input-bar {
        padding: 0.75rem 1rem;
        background: var(--bg-dark);
        border-top: 1px solid var(--border-color);
        flex-shrink: 0;
    }

    .input-group {
        display: flex;
        gap: 10px;
        align-items: flex-end;
    }

    #chatInput {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        font-size: 0.9rem;
        border-radius: 28px;
        padding: 0.7rem 1.2rem;
        resize: none;
        flex: 1;
    }
    #chatInput:focus {
        background: var(--bg-card);
        border-color: var(--accent-blue);
        color: var(--text-primary);
        box-shadow: 0 0 0 2px rgba(88,166,255,0.15);
        outline: none;
    }
    #chatInput::placeholder {
        color: var(--text-muted);
    }

    /* Buttons */
    .btn-primary, .btn-outline-secondary {
        border-radius: 40px !important;
        width: 44px;
        height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border: 1px solid var(--border-color);
        background: var(--bg-card);
        color: var(--text-primary);
        transition: 0.2s;
    }
    .btn-primary {
        background: var(--accent-blue);
        border-color: var(--accent-blue);
        color: #0d1117;
    }
    .btn-primary:hover {
        background: #79c0ff;
        transform: scale(0.97);
    }
    .btn-outline-secondary:hover {
        background: rgba(88,166,255,0.1);
        border-color: var(--accent-blue);
    }

    /* Token & clear row */
    .badge.bg-secondary {
        background: var(--bg-card) !important;
        color: var(--text-primary);
        border: 1px solid var(--border-color);
        border-radius: 40px;
        padding: 0.35rem 0.9rem;
        font-weight: 500;
    }
    #clearBtn {
        border-radius: 2rem;
        padding: 0.25rem 1rem;
        background: var(--bg-card);
        border-color: var(--border-color);
        color: var(--text-primary);
    }
    #clearBtn:hover {
        background: rgba(248,81,73,0.2);
        border-color: #f85149;
        color: #f85149;
    }
    small.text-secondary {
        color: var(--text-muted) !important;
    }

    /* Animations */
    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── Responsive adjustments ─────────────────────────────────────────── */
    @@media (max-width: 640px) {
        .chat-messages {
            padding: 1rem 0.8rem;
        }
        .message {
            max-width: 95%;
        }
        .message-avatar {
            width: 28px;
            height: 28px;
            font-size: 0.8rem;
        }
        .message-bubble {
            font-size: 0.85rem;
            padding: 0.5rem 0.9rem;
        }
        .btn-primary, .btn-outline-secondary {
            width: 40px;
            height: 40px;
        }
    }
    @@media (min-width: 1024px) {
        .message {
            max-width: 75%;
        }
    }
</style>

<div class="chat-layout">
    <!-- Message history -->
    <div class="chat-messages" id="chatMessages">
        <div class="message assistant">
            <div class="message-avatar"><i class="bi bi-robot"></i></div>
            <div class="message-bubble">
                Hello! I'm your Dev Assistant. I can read files, run tests,
                search your codebase semantically, and suggest code fixes.
                What would you like to work on?
            </div>
        </div>
    </div>

    <!-- Input bar -->
    <div class="chat-input-bar">
        <div class="input-group">
            <textarea id="chatInput"
                      class="form-control"
                      rows="2"
                      placeholder="Ask me to read a file, run tests, search code..."
                      style="resize:none;"></textarea>
            <button class="btn btn-primary" id="sendBtn" title="Send (Ctrl+Enter)">
                <i class="bi bi-send-fill"></i>
            </button>
            <button class="btn btn-outline-secondary" id="stopBtn"
                    title="Stop generation" style="display:none">
                <i class="bi bi-stop-fill"></i>
            </button>
        </div>
        <div class="d-flex gap-2 mt-2 align-items-center">
            <small class="text-secondary">Enter to send · Shift+Enter for new line</small>
            <div class="ms-auto d-flex gap-2 align-items-center">
                <span class="badge bg-secondary" id="tokenCount">0 tokens</span>
                <button class="btn btn-sm btn-outline-secondary" id="clearBtn">
                    <i class="bi bi-trash me-1"></i>Clear
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const messagesEl = document.getElementById('chatMessages');
        const inputEl    = document.getElementById('chatInput');
        const sendBtn    = document.getElementById('sendBtn');
        const stopBtn    = document.getElementById('stopBtn');
        const clearBtn   = document.getElementById('clearBtn');
        const tokenEl    = document.getElementById('tokenCount');

        let controller = null;
        let totalTokens = 0;

        // --- Enter to send (without Shift), Shift+Enter adds newline ---
        inputEl.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                send();
            } else if (e.key === 'Enter' && e.shiftKey) {
                // allow default: insert newline
                return;
            }
            // Keep Ctrl+Enter as fallback (optional, but still works)
            if (e.ctrlKey && e.key === 'Enter') {
                e.preventDefault();
                send();
            }
        });

        sendBtn.addEventListener('click', send);
        stopBtn.addEventListener('click', () => { if (controller) controller.abort(); });
        clearBtn.addEventListener('click', () => {
            messagesEl.innerHTML = '';
            totalTokens = 0;
            tokenEl.textContent = '0 tokens';
        });

        function appendMessage(role, content = '') {
            const wrapper = document.createElement('div');
            wrapper.className = `message ${role}`;

            const avatar = document.createElement('div');
            avatar.className = 'message-avatar';
            avatar.innerHTML = role === 'user'
                ? '<i class="bi bi-person-fill"></i>'
                : '<i class="bi bi-robot"></i>';

            const bubble = document.createElement('div');
            bubble.className = 'message-bubble';
            bubble.textContent = content;

            wrapper.appendChild(avatar);
            wrapper.appendChild(bubble);
            messagesEl.appendChild(wrapper);
            messagesEl.scrollTop = messagesEl.scrollHeight;
            return bubble;
        }

        async function send() {
            const text = inputEl.value.trim();
            if (!text) return;

            inputEl.value = '';
            appendMessage('user', text);

            const bubble = appendMessage('assistant');
            bubble.innerHTML = '<span class="typing-indicator"><span></span><span></span><span></span></span>';

            sendBtn.style.display = 'none';
            stopBtn.style.display = '';

            controller = new AbortController();
            let fullText = '';

            try {
                const url = `/chat/stream?message=${encodeURIComponent(text)}`;
                const es = new EventSource(url);

                es.onmessage = (e) => {
                    if (e.data === '[DONE]') {
                        es.close();
                        done();
                        return;
                    }
                    try {
                        const d = JSON.parse(e.data);
                        if (d.error) {
                            bubble.textContent = '⚠️ ' + d.error;
                            es.close(); done(); return;
                        }
                        fullText += d.token;
                        totalTokens++;
                        tokenEl.textContent = totalTokens + ' tokens';

                        // Render markdown-ish (code blocks highlighted)
                        bubble.innerHTML = renderContent(fullText);
                        messagesEl.scrollTop = messagesEl.scrollHeight;
                    } catch {}
                };

                es.onerror = () => { es.close(); done(); };

            } catch (err) {
                bubble.textContent = '⚠️ ' + err.message;
                done();
            }
        }

        function done() {
            sendBtn.style.display = '';
            stopBtn.style.display = 'none';
            controller = null;
            // Re-highlight code blocks
            messagesEl.querySelectorAll('pre code').forEach(el => hljs.highlightElement(el));
        }

        function renderContent(text) {
            // Strip any raw JSON tool result the LLM might echo
            text = text.replace(/\{"success":(true|false).*?\}/gs, '');

            return text
                .replace(/```(\w+)?\n([\s\S]*?)```/g, (_, lang, code) =>
                    `<pre><code class="${lang || ''}">${escHtml(code.trim())}</code></pre>`)
                .replace(/`([^`]+)`/g, '<code class="inline-code">$1</code>')
                .replace(/\n/g, '<br>');
        }

        function escHtml(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }
    </script>
}